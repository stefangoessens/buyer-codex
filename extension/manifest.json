{
  "manifest_version": 3,
  "name": "buyer-codex Listing Saver",
  "version": "0.1.0",
  "description": "Save Zillow, Redfin, and Realtor.com listings directly to your buyer-codex deal room.",
  "action": {
    "default_title": "Save to buyer-codex",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://*.zillow.com/*",
    "https://*.redfin.com/*",
    "https://*.realtor.com/*",
    "https://buyer-codex.app/*",
    "https://*.buyer-codex.app/*",
    "http://localhost:3000/*"
  ]
}
