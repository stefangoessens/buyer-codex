# buyer-codex environment variables
#
# Copy to .env.local and fill in real values for local dev.
# Production values live in Railway (railway variables --set KEY=VALUE).
#
# Add new environment variables here when the application surface expands.

# ─────────────────────────────────────────────
# Deployment model
# ─────────────────────────────────────────────
# Explicit stage contract shared across local, preview, staging, and production.
# Railway preview/staging/production metadata still wins when available.
BUYER_CODEX_ENV=local
OBSERVABILITY_SERVICE_NAME=buyer-codex-web

# ─────────────────────────────────────────────
# Convex backend
# ─────────────────────────────────────────────
# Set automatically by `npx convex dev` — do not hand-edit
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Convex deploy key for CI / Railway production deploys
CONVEX_DEPLOY_KEY=

# ─────────────────────────────────────────────
# AI providers
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
# Sentry — error tracking (web, convex, workers)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kindservices
SENTRY_PROJECT=buyer-codex-web
NEXT_PUBLIC_SENTRY_DSN=

# PostHog — product analytics + funnels
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ─────────────────────────────────────────────
# Auth (Convex Better Auth runtime: Google OAuth + magic-link email)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
AUTH_EMAIL_FROM=

# ─────────────────────────────────────────────
# Property ingestion
# ─────────────────────────────────────────────
# BRIGHT_DATA_UNLOCKER_TOKEN=
# BRIGHT_DATA_ZONE=buyer_codex_unlocker
# BRIGHT_DATA_MAX_CONCURRENT=4
# BRIGHT_DATA_MAX_REQUESTS_PER_MIN=60
# BRIGHT_DATA_MONTHLY_BUDGET_USD=500
# BRIGHT_DATA_FALLBACK_COST_PER_REQUEST_USD=0.0015
# BROWSER_USE_API_KEY=
# RENTCAST_API_KEY=
# ATTOM_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Communication (P4)
# ─────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────
# Railway (set by Railway runtime — do not commit)
# ─────────────────────────────────────────────
# RAILWAY_ENVIRONMENT=
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_NAME=
# PORT=
# Worker service example:
# CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# Linear
# ─────────────────────────────────────────────
LINEAR_TEAM_KEY=KIN
LINEAR_PROJECT=buyer-codex

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Canonical web origin used by metadata, sitemap, and route shells
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
