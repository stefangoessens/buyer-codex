# buyer-codex environment variables
#
# Copy to .env.local and fill in real values for local dev.
# Production values live in Railway (railway variables --set KEY=VALUE).
#
# Add new environment variables here when the application surface expands.

# ─────────────────────────────────────────────
# Convex backend
# ─────────────────────────────────────────────
# Set automatically by `npx convex dev` — do not hand-edit
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex deploy key for CI / Railway production deploys
CONVEX_DEPLOY_KEY=

# ─────────────────────────────────────────────
# AI providers
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
# Sentry — error tracking (web, convex, workers)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kindservices
SENTRY_PROJECT=buyer-codex-web
NEXT_PUBLIC_SENTRY_DSN=

# PostHog — product analytics + funnels
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# ─────────────────────────────────────────────
# Auth (primary: Clerk, fallback: Auth0)
# ─────────────────────────────────────────────
NEXT_PUBLIC_AUTH_PROVIDER=clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
CONVEX_CLERK_APPLICATION_ID=convex

# Optional fallback OIDC path
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER_BASE_URL=
AUTH0_API_AUDIENCE=

# ─────────────────────────────────────────────
# Property ingestion
# ─────────────────────────────────────────────
# BRIGHT_DATA_UNLOCKER_TOKEN=
# BRIGHT_DATA_ZONE=buyer_codex_unlocker
# BRIGHT_DATA_MAX_CONCURRENT=4
# BRIGHT_DATA_MAX_REQUESTS_PER_MIN=60
# BRIGHT_DATA_MONTHLY_BUDGET_USD=500
# BRIGHT_DATA_FALLBACK_COST_PER_REQUEST_USD=0.0015
# BROWSER_USE_API_KEY=
# RENTCAST_API_KEY=
# ATTOM_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Communication (P4)
# ─────────────────────────────────────────────
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────
# Railway (set by Railway runtime — do not commit)
# ─────────────────────────────────────────────
# RAILWAY_ENVIRONMENT=
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_NAME=
# PORT=

# ─────────────────────────────────────────────
# Linear
# ─────────────────────────────────────────────
LINEAR_TEAM_KEY=KIN
LINEAR_PROJECT=buyer-codex

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Canonical web origin used by metadata, sitemap, and route shells
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
